{
  "name": "sera-second-brain",
  "version": "1.0.0",
  "description": "WhatsApp-based Second Brain & Productivity Assistant powered by AI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "prisma:push": "npx prisma db push",
    "prisma:studio": "npx prisma studio"
  },
  "dependencies": {
    "@google/genai": "^1.3.0",
    "@hapi/boom": "^10.0.1",
    "@prisma/client": "^6.9.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.6.0",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "nodemon": "^3.1.9",
    "prisma": "^6.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
