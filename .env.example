# Environment
NODE_ENV=development
TIMEZONE=Asia/Colombo

# MongoDB — Prisma connection string
DATABASE_URL="mongodb://user:password@localhost:27017/sera_brain?authSource=admin&directConnection=true"

# Redis — BullMQ connection
REDIS_URL="redis://localhost:6379"

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"
AI_MODEL="gemini-2.0-flash"
